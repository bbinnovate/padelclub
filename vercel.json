{
  "rewrites": [
    {
      "source": "/config.js",
      "destination": "/api/config.js"
    },
    {
      "source": "/",
      "destination": "/view/index.html"
    },
    {
      "source": "/admin",
      "destination": "/view/admin.html"
    },
    {
      "source": "/admin/",
      "destination": "/view/admin.html"
    },
    {
      "source": "/login",
      "destination": "/view/login.html"
    },
    {
      "source": "/login/",
      "destination": "/view/login.html"
    }
  ]
}
